<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement name="Root" style="flex-grow: 1; align-content: flex-end; width: 100%; height: 100%; align-items: auto; justify-content: center;">
        <ui:VisualElement name="Cursor" style="flex-grow: 1; width: 20px; height: 20px; top: 0%; left: 0%; bottom: 0%; right: 0%; min-height: 0; min-width: 0; max-width: 20px; max-height: 20px; align-self: center; align-content: center; -unity-background-image-tint-color: rgb(255, 203, 78); background-color: rgba(255, 185, 17, 0); border-left-color: rgba(255, 187, 41, 0); border-right-color: rgba(255, 187, 41, 0); border-top-color: rgba(255, 187, 41, 0); border-bottom-color: rgba(255, 187, 41, 0); border-top-width: 2px; border-right-width: 2px; border-bottom-width: 2px; border-left-width: 2px; border-top-left-radius: 20px; border-top-right-radius: 20px; border-bottom-right-radius: 20px; border-bottom-left-radius: 20px;"/>
    </ui:VisualElement>
    <ui:VisualElement name="Loading" style="flex-grow: 1; background-color: rgba(255, 255, 255, 0); position: absolute; bottom: 0; width: 100%; height: 2px; transform-origin: bottom;">
        <ui:Label text="Label" name="Information" style="position: absolute; bottom: 2px; width: 100%; color: rgba(255, 255, 255, 0);"/>
        <ui:VisualElement name="Progress" style="flex-grow: 1; background-color: rgb(255, 184, 0); position: absolute; bottom: 0; width: 0%; height: 100%; transform-origin: bottom; align-self: flex-start;"/>
    </ui:VisualElement>
</ui:UXML>
